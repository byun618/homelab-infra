# home-coffing API runtime secrets
# 실제 .env 파일은 gitignored. mac mini의 services/home-coffing/.env 에 위치.

# DB (homelab mysql)
DB_USER=home_coffing
DB_PASSWORD=
DB_NAME=home_coffing

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# 분석 (003 placeholder, T006에서 활용 예정)
AMPLITUDE_API_KEY=

# FCM (푸시 알림)
FCM_SERVICE_ACCOUNT_JSON=

# (선택) 워크플로가 deploy 시 override. 미설정 시 :latest 사용
# API_IMAGE_TAG=main-abc1234
